# =====================================================================
# Environment variable template for clinic_website.
# Copy to ".env" and fill in real values. The real ".env" is gitignored
# and must NEVER be committed. In production, inject these via the
# platform's secrets manager (CI secrets, Docker/K8s secrets, vault).
# =====================================================================

# --- Core Django ---
# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
# 1 = on (local dev only). MUST be 0 in production.
DEBUG=0
# Comma-separated hostnames, e.g. clinic.example.com,www.clinic.example.com
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated, scheme-qualified, e.g. https://clinic.example.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# --- Database (PostgreSQL) ---
DB_NAME=clinic_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- Cache (Redis) ---
REDIS_URL=redis://127.0.0.1:6379

# --- Feature flags (secure-by-default; set to 0 only for dev/testing) ---
# NOTE: with DEBUG=0 these MUST be 1 — `manage.py check --deploy` fails with
# accounts.E001/E002 otherwise. Run it in your deploy pipeline.
ENFORCE_PHONE_VERIFICATION=1
ENFORCE_OTP_LIMITS=1

# --- Login brute-force throttle (optional; sensible defaults in settings.py) ---
# Per-account (phone) layer: N failures then an escalating block (15m/1h/24h).
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=900
# Per-IP layer: higher cap, since one IP can be many users behind NAT.
LOGIN_IP_MAX_ATTEMPTS=20
LOGIN_IP_WINDOW_SECONDS=900

# --- SMS provider (TweetsMS) ---
SMS_PROVIDER=TWEETSMS
TWEETSMS_API_KEY=
TWEETSMS_SENDER=
TWEETSMS_BASE_URL=https://tweetsms.ps/api.php

# --- Email provider (Brevo / SendinBlue) ---
BREVO_API_KEY=
